<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="/meander_custom/custom.css?version=29" rel="stylesheet" type="text/css"/>
    <link href="/meander/meander.css?version=27" rel="stylesheet" type="text/css"/>
    {% if extraJs %}
    <script type="text/javascript" src='{{ extraJs }}'></script>
    {% endif %}
    {% if extraCss %}
    <link href="{{ extraCss }}" rel="stylesheet" type="text/css"/>
    {% endif %}
    <title>{{ title | default("Averemo") }}</title>
</head>
<body>

<div id="container">
<div id="header">
  <div id="leftheader">
      <a href="/"> <img src="/images/flag_cropped.png" style="width:30vw" alt="Averemo Flag"></a>
  </div>
  <div id="rightheader">
    <h1>Averemo</h1>
    <h2>- shared truth -</h2>
    <div style="font-size: 1.2em; margin-top: 15px; display: flex; gap: 10px; align-items: center; justify-content: flex-end;">
      <span style="font-size: 0.6em; text-transform: uppercase; letter-spacing: 1px; color: #555;">Share:</span>
      <a href="https://www.facebook.com/sharer/sharer.php?u=https://averemo.org{{ page.url }}" target="_blank" rel="noopener" title="Share on Facebook" style="color: #1877F2;">
        <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M22.675 0H1.325C.593 0 0 .593 0 1.325v21.351C0 23.407.593 24 1.325 24H12.82v-9.294H9.692v-3.622h3.128V8.413c0-3.1 1.893-4.788 4.659-4.788 1.325 0 2.463.099 2.795.143v3.24l-1.918.001c-1.504 0-1.795.715-1.795 1.763v2.313h3.587l-.467 3.622h-3.12V24h6.116c.73 0 1.323-.593 1.323-1.325V1.325C24 .593 23.407 0 22.675 0z"/></svg>
      </a>
      <a href="https://twitter.com/intent/tweet?url=https://averemo.org{{ page.url }}&text={{ title | urlencode }}" target="_blank" rel="noopener" title="Share on X (Twitter)" style="color: #000;">
        <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/></svg>
      </a>
      <a href="https://truthsocial.com/share?text={{ title | urlencode }}&url=https://averemo.org{{ page.url }}" target="_blank" rel="noopener" title="Share on Truth Social" style="color: #5d3b8f;">
        <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M3 0h18a3 3 0 0 1 3 3v18a3 3 0 0 1-3 3H3a3 3 0 0 1-3-3V3a3 3 0 0 1 3-3Zm5 8v2h3v8h4v-8h3V8H8Z"/></svg>
      </a>
      <a href="https://bsky.app/intent/compose?text={{ title | urlencode }}%20https://averemo.org{{ page.url }}" target="_blank" rel="noopener" title="Share on BlueSky" style="color: #0085ff;">
        <svg width="20" height="20" fill="currentColor" viewBox="0 0 16 16"><path d="M3.204 4.011c3.106-2.14 4.266-3.056 4.796-3.056.53 0 1.69.916 4.796 3.056 1.848 1.282 2.775 3.129 2.052 5.097-.56 1.543-2.162 2.083-3.957 2.072l.462.146c1.298.414 1.865 1.536 1.378 2.502-.457.925-1.603 1.21-3.21.654L8 10.985l-1.521 3.498c-1.607.555-2.753.27-3.21-.655-.487-.966.08-2.088 1.378-2.502l.462-.146c-1.795.011-3.397-.53-3.957-2.072-.723-1.968.204-3.815 2.052-5.097z"/></svg>
      </a>
    </div>
  </div>
  <br class="clearfloat"/>
</div>

<!-- Navigation Bar ******************************** -->
<div id="topnav">
  <ul>
    <li><a href="/">Home</a></li>
    <li><a href="/topics/">Topics</a></li>
    <li><a href="/articles/">Articles</a></li>
    <li><a href="/about/">About Us</a></li>
  </ul>
</div>

<div id="content">
<!-- Begin Content DIV ******************************** -->

{{ content | safe }}

<!-- end content div ******************************** -->
</div>

<div id="footer">
  <p class="copyright">&copy; 2025 Averemo - All Rights Reserved | <a href="/privacy/">Privacy Policy</a></p>
</div>
<!-- end container div ******************************** -->
</div>

</body>
</html>
